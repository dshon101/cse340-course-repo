<%- include('./partials/header') %>

    <section class="page-hero">
        <div class="container">
            <h1 class="page-title">
                <%= title %>
            </h1>
            <p class="page-subtitle">Explore active service projects and find volunteer opportunities that match your passion.</p>
        </div>
    </section>

    <section class="projects-section">
        <div class="container">
            <div class="projects-list">

                <% projects.forEach(project=> { %>
                    <article class="project-card">
                        <div class="project-meta">
                            <span class="project-date">
                                <%= new Date(project.project_date).toLocaleDateString('en-US', { year: 'numeric' , month: 'long' , day: 'numeric' , timeZone: 'UTC' }) %>
                            </span>
                        </div>
                        <h2>
                            <%= project.title %>
                        </h2>
                        <p>
                            <%= project.description %>
                        </p>
                        <div class="project-footer">
                            <span class="project-org">◈ <%= project.organization_name %></span>
                            <span class="project-location">📍 <%= project.location %></span>
                        </div>
                    </article>
                    <% }); %>

            </div>
        </div>
    </section>

    <%- include('./partials/footer') %>