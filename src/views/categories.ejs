<%- include('./partials/header') %>

    <section class="page-hero">
        <div class="container">
            <h1 class="page-title">
                <%= title %>
            </h1>
            <p class="page-subtitle">Find service opportunities organized by cause and impact area.</p>
        </div>
    </section>

    <section class="categories-section">
        <div class="container">
            <div class="categories-grid">

                <% categories.forEach(category=> { %>
                    <article class="category-card">
                        <h2>
                            <%= category.name %>
                        </h2>
                        <a href="/projects" class="btn btn-outline btn-sm">Browse Projects</a>
                    </article>
                    <% }); %>

            </div>
        </div>
    </section>

    <%- include('./partials/footer') %>