<%- include('./partials/header') %>

    <section class="page-hero">
        <div class="container">
            <h1 class="page-title">
                <%= title %>
            </h1>
            <p class="page-subtitle">Meet the organizations driving change in our communities.</p>
        </div>
    </section>

    <section class="org-section">
        <div class="container">
            <div class="org-grid">

                <% organizations.forEach(organization=> { %>
                    <article class="org-card">
                        <div class="org-img-wrap">
                            <img src="/images/<%= organization.logo_filename %>" alt="<%= organization.name %> logo" />
                        </div>
                        <div class="org-body">
                            <h2>
                                <%= organization.name %>
                            </h2>
                            <p>
                                <%= organization.description %>
                            </p>
                            <p>
                                <%= organization.contact_email %>
                            </p>
                            <a href="#" class="btn btn-sm">Learn More</a>
                        </div>
                    </article>
                    <% }); %>

            </div>
        </div>
    </section>

    <%- include('./partials/footer') %>